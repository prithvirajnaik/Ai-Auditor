# Gemini API Key (Optional: for live audit summaries)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Resend API Key (Optional: for transactional emails)
RESEND_API_KEY="MY_RESEND_API_KEY"

# Supabase Credentials (Optional: for persistence; falls back to in-memory/localStorage)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

# Client environment keys for direct build checks
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# App URL
APP_URL="http://localhost:3000"
